# Base de datos PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/amigurumishop"

# JWT — secreto de al menos 32 caracteres
# Generar con: openssl rand -hex 32
JWT_SECRET="cambia-este-secreto-por-uno-seguro-de-al-menos-32-chars"

# Hash bcrypt de la contraseña del admin
# Generar con: npm run hash-password "tu-contraseña"
ADMIN_PASSWORD_HASH="$2b$10$reemplaza_esto_con_tu_hash_real"

# URL del frontend (para CORS)
FRONTEND_URL="http://localhost:5173"

# Puerto del servidor (opcional, default: 3001)
PORT=3001

# Entorno
NODE_ENV="development"

# Número de WhatsApp para el seed inicial (solo primera vez)
DEFAULT_WHATSAPP="51987654321"
