generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Category {
  ANIME
  ANIMALS
  CHARACTERS
  OTHERS
}

model Product {
  id          String   @id @default(cuid())
  name        String
  price       Decimal  @db.Decimal(10, 2)
  category    Category
  description String?
  imageUrl    String
  available   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([available])
  @@index([available, category])
}

model Config {
  id             String   @id @default(cuid())
  whatsappNumber String   @default("")
  storeName      String   @default("AmigurumiShop")
  currencySymbol String   @default("S/.")
  updatedAt      DateTime @updatedAt
}
